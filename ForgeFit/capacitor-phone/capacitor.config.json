{
  "appId": "co.rakshitr.forgefit",
  "appName": "ForgeFit",
  "server": {
    "url": "https://forgefit.rakshitr.co.in/app/",
    "cleartext": false,
    "androidScheme": "https"
  },
  "android": {
    "allowMixedContent": false,
    "backgroundColor": "#000000",
    "overrideUserAgent": "ForgeFit-Android/1.0"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 1800,
      "backgroundColor": "#000000",
      "androidSpinnerStyle": "small",
      "spinnerColor": "#e8002d",
      "showSpinner": false,
      "splashFullScreen": true,
      "splashImmersive": true
    },
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#000000",
      "overlaysWebView": true
    }
  }
}
